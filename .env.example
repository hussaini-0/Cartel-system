# Copy this file to .env and fill in the values

# MongoDB Atlas connection string (create a free cluster at https://mongodb.com/atlas)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# Admin panel password (choose anything)
ADMIN_PASSWORD=yourPasswordHere

# JWT secret — generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replaceWithALongRandomString

# Your JazzCash number for payment instructions
JAZZCASH_NUMBER=03001234567

# The URL where the admin panel is served (use your local IP for LAN access)
CORS_ORIGIN=http://localhost:5000
