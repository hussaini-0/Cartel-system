{
  "name": "cartel-system",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "start:bot": "node whatsapp.js",
    "start:desktop": "electron .",
    "dist:win": "electron-builder --win nsis",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.cartel.pos",
    "productName": "Cartel POS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "admin/**/*",
      "controllers/**/*",
      "electron/**/*",
      "middleware/**/*",
      "models/**/*",
      "routes/**/*",
      "services/**/*",
      ".env.example",
      "offlineStore.js",
      "package.json",
      "runtimePaths.js",
      "server.js",
      "whatsapp.js"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": "nsis"
    }
  }
}
